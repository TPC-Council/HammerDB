# tcl pkg-config source file

prefix=/opt/HammerDB-master/Build/BawtBuild/Linux/x64/Release/Install/Tcl
exec_prefix=/opt/HammerDB-master/Build/BawtBuild/Linux/x64/Release/Install/Tcl
libdir=/opt/HammerDB-master/Build/BawtBuild/Linux/x64/Release/Install/Tcl/lib
includedir=${prefix}/include

Name: Tool Command Language
Description: Tcl is a powerful, easy-to-learn dynamic programming language, suitable for a wide range of uses.
URL: https://www.tcl-tk.org/
Version: 8.6.12
Requires.private: zlib >= 1.2.3
Libs: -L${libdir} -ltcl8.6 -ltclstub8.6
Libs.private: -ldl -lz  -lpthread -lm
Cflags: -I${includedir}
