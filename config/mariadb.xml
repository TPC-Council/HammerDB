<?xml version="1.0" encoding="utf-8"?>
<mariadb>
    <connection>
        <maria_host>127.0.0.1</maria_host>
        <maria_port>3306</maria_port>
        <maria_socket>/tmp/mariadb.sock</maria_socket>
        <maria_ssl>false</maria_ssl>
        <maria_ssl_two_way>false</maria_ssl_two_way>
        <maria_ssl_linux_capath>/etc/mysql/certs</maria_ssl_linux_capath>
        <maria_ssl_windows_capath>C:\mysql\certs</maria_ssl_windows_capath>
        <maria_ssl_ca>ca-cert.pem</maria_ssl_ca>
        <maria_ssl_cert>client-cert.pem</maria_ssl_cert>
        <maria_ssl_key>client-key.pem</maria_ssl_key>
        <maria_ssl_cipher>server</maria_ssl_cipher>
    </connection>
    <tpcc>
        <schema>
            <maria_count_ware>1</maria_count_ware>
            <maria_num_vu>1</maria_num_vu>
            <maria_user>root</maria_user>
            <maria_pass>maria</maria_pass>
            <maria_dbase>tpcc</maria_dbase>
            <maria_storage_engine>innodb</maria_storage_engine>
            <maria_partition>false</maria_partition>
            <maria_prepared>false</maria_prepared>
            <maria_no_stored_procs>false</maria_no_stored_procs>
            <maria_history_pk>false</maria_history_pk>
            <maria_tidesdb_compression>lz4</maria_tidesdb_compression>
            <maria_tidesdb_sync_mode>full</maria_tidesdb_sync_mode>
            <maria_tidesdb_write_buffer_size>33554432</maria_tidesdb_write_buffer_size>
            <maria_tidesdb_bloom_filter>true</maria_tidesdb_bloom_filter>
            <maria_tidesdb_block_indexes>true</maria_tidesdb_block_indexes>
            <maria_tidesdb_use_btree>false</maria_tidesdb_use_btree>
            <maria_tidesdb_isolation_level>repeatable_read</maria_tidesdb_isolation_level>
            <maria_tidesdb_bloom_fpr>100</maria_tidesdb_bloom_fpr>
            <maria_tidesdb_sync_interval_us>128000</maria_tidesdb_sync_interval_us>
            <maria_tidesdb_klog_value_threshold>4096</maria_tidesdb_klog_value_threshold>
            <maria_tidesdb_min_disk_space>104857600</maria_tidesdb_min_disk_space>
            <maria_tidesdb_index_sample_ratio>1</maria_tidesdb_index_sample_ratio>
            <maria_tidesdb_block_index_prefix_len>16</maria_tidesdb_block_index_prefix_len>
            <maria_tidesdb_level_size_ratio>10</maria_tidesdb_level_size_ratio>
            <maria_tidesdb_min_levels>5</maria_tidesdb_min_levels>
            <maria_tidesdb_dividing_level_offset>2</maria_tidesdb_dividing_level_offset>
            <maria_tidesdb_skip_list_max_level>12</maria_tidesdb_skip_list_max_level>
            <maria_tidesdb_skip_list_probability>25</maria_tidesdb_skip_list_probability>
            <maria_tidesdb_l1_file_count_trigger>4</maria_tidesdb_l1_file_count_trigger>
            <maria_tidesdb_l0_queue_stall_threshold>10</maria_tidesdb_l0_queue_stall_threshold>
            <maria_tidesdb_ttl>0</maria_tidesdb_ttl>
            <maria_tidesdb_encrypted>no</maria_tidesdb_encrypted>
            <maria_tidesdb_encryption_key_id>1</maria_tidesdb_encryption_key_id>
        </schema>
        <driver>
            <maria_total_iterations>10000000</maria_total_iterations>
            <maria_raiseerror>false</maria_raiseerror>
            <maria_keyandthink>false</maria_keyandthink>
            <maria_driver>timed</maria_driver>
            <maria_rampup>2</maria_rampup>
            <maria_duration>5</maria_duration>
            <maria_allwarehouse>false</maria_allwarehouse>
            <maria_timeprofile>false</maria_timeprofile>
            <maria_async_scale>false</maria_async_scale>
            <maria_async_client>10</maria_async_client>
            <maria_async_verbose>false</maria_async_verbose>
            <maria_async_delay>1000</maria_async_delay>
            <maria_connect_pool>false</maria_connect_pool>
            <maria_purge>false</maria_purge>
        </driver>
    </tpcc>
    <tpch>
        <schema>
            <maria_scale_fact>1</maria_scale_fact>
            <maria_tpch_user>root</maria_tpch_user>
            <maria_tpch_pass>maria</maria_tpch_pass>
            <maria_tpch_dbase>tpch</maria_tpch_dbase>
            <maria_num_tpch_threads>1</maria_num_tpch_threads>
            <maria_tpch_storage_engine>innodb</maria_tpch_storage_engine>
            <maria_tpch_tidesdb_compression>lz4</maria_tpch_tidesdb_compression>
            <maria_tpch_tidesdb_sync_mode>full</maria_tpch_tidesdb_sync_mode>
            <maria_tpch_tidesdb_write_buffer_size>33554432</maria_tpch_tidesdb_write_buffer_size>
            <maria_tpch_tidesdb_bloom_filter>true</maria_tpch_tidesdb_bloom_filter>
            <maria_tpch_tidesdb_block_indexes>true</maria_tpch_tidesdb_block_indexes>
            <maria_tpch_tidesdb_use_btree>false</maria_tpch_tidesdb_use_btree>
            <maria_tpch_tidesdb_isolation_level>repeatable_read</maria_tpch_tidesdb_isolation_level>
            <maria_tpch_tidesdb_bloom_fpr>100</maria_tpch_tidesdb_bloom_fpr>
            <maria_tpch_tidesdb_sync_interval_us>128000</maria_tpch_tidesdb_sync_interval_us>
            <maria_tpch_tidesdb_klog_value_threshold>4096</maria_tpch_tidesdb_klog_value_threshold>
            <maria_tpch_tidesdb_min_disk_space>104857600</maria_tpch_tidesdb_min_disk_space>
            <maria_tpch_tidesdb_index_sample_ratio>1</maria_tpch_tidesdb_index_sample_ratio>
            <maria_tpch_tidesdb_block_index_prefix_len>16</maria_tpch_tidesdb_block_index_prefix_len>
            <maria_tpch_tidesdb_level_size_ratio>10</maria_tpch_tidesdb_level_size_ratio>
            <maria_tpch_tidesdb_min_levels>5</maria_tpch_tidesdb_min_levels>
            <maria_tpch_tidesdb_dividing_level_offset>2</maria_tpch_tidesdb_dividing_level_offset>
            <maria_tpch_tidesdb_skip_list_max_level>12</maria_tpch_tidesdb_skip_list_max_level>
            <maria_tpch_tidesdb_skip_list_probability>25</maria_tpch_tidesdb_skip_list_probability>
            <maria_tpch_tidesdb_l1_file_count_trigger>4</maria_tpch_tidesdb_l1_file_count_trigger>
            <maria_tpch_tidesdb_l0_queue_stall_threshold>10</maria_tpch_tidesdb_l0_queue_stall_threshold>
            <maria_tpch_tidesdb_ttl>0</maria_tpch_tidesdb_ttl>
            <maria_tpch_tidesdb_encrypted>no</maria_tpch_tidesdb_encrypted>
            <maria_tpch_tidesdb_encryption_key_id>1</maria_tpch_tidesdb_encryption_key_id>
        </schema>
        <driver>
            <maria_total_querysets>1</maria_total_querysets>
            <maria_raise_query_error>false</maria_raise_query_error>
            <maria_verbose>false</maria_verbose>
            <maria_refresh_on>false</maria_refresh_on>
            <maria_update_sets>1</maria_update_sets>
            <maria_trickle_refresh>1000</maria_trickle_refresh>
            <maria_refresh_verbose>false</maria_refresh_verbose>
            <maria_cloud_query>false</maria_cloud_query>
        </driver>
    </tpch>
</mariadb>
